# ============================================================
# VitalLoop — environment variable template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# NEVER place real PHI or production credentials in this file.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=vitalloop
POSTGRES_PASSWORD=changeme_local
POSTGRES_DB=vitalloop

# ── Google Cloud Pub/Sub Emulator ────────────────────────────
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=vitalloop-local

# ── HAPI FHIR (local) ────────────────────────────────────────
FHIR_BASE_URL=http://localhost:8090/fhir

# ── GCP / Vertex AI (production / staging) ──────────────────
# Leave blank for local dev; set in CI/CD secrets or Secret Manager.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
