# ============================================================
# VitalLoop .gitignore
# ============================================================

# ── SECURITY: never commit real environment secrets ──────────
.env
*.env.local
*.env.production

# ── Java / Maven ─────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Maven wrapper cache
.mvn/repository/

# ── Spring Boot ──────────────────────────────────────────────
HELP.md
spring-shell.log

# ── Node / npm / yarn ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
dist/
build/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist/

# ── Terraform ────────────────────────────────────────────────
infra/.terraform/
infra/.terraform.lock.hcl
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfvars
infra/override.tf
infra/override.tf.json
infra/*_override.tf
infra/*_override.tf.json
infra/.terraformrc
infra/terraform.rc

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── IDE — IntelliJ IDEA ──────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── IDE — VS Code ────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# ── IDE — Eclipse ────────────────────────────────────────────
.classpath
.project
.settings/
bin/

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Windows ──────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── Test / coverage artefacts ────────────────────────────────
.jacoco/
jacoco.exec
